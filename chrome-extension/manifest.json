{
  "manifest_version": 3,
  "name": "Browser MCP",
  "version": "1.0.0",
  "description": "让 AI 通过 MCP 协议安全访问你浏览器中已登录的网站数据",
  "permissions": [
    "nativeMessaging",
    "userScripts",
    "scripting",
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://*.taobao.com/*",
    "https://*.tmall.com/*",
    "https://*.jd.com/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Browser MCP"
  }
}

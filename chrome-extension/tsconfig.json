{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "verbatimModuleSyntax": true,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["background.ts", "popup/popup.ts", "manager/manager.ts"],
  "exclude": ["node_modules", "dist"]
}
